<Window x:Class="UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Auto Affection Skip" Height="500" Width="360"
        Background="#F3F7F8">

    <Window.Resources>
        <!-- 포인트 컬러 설정 -->
        <SolidColorBrush x:Key="Pink" Color="#fd8ca0"/>
        <SolidColorBrush x:Key="DarkPink" Color="#e87a8e"/>

        <!-- 버튼 스타일 -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Pink}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="12" 
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource DarkPink}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#cccccc"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 리스트박스 -->
        <Style x:Key="ChatListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- 상단 헤더 -->
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 상단 바 -->
        <Border Grid.Row="0" Background="{StaticResource Pink}">
            <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" 
                       Foreground="White" FontSize="18" FontWeight="Bold"/>
        </Border>

        <!-- 로그 출력 부분 -->
        <ListBox x:Name="LogListBox"
                 Grid.Row="1"
                 ItemsSource="{Binding Logs}" 
                 Style="{StaticResource ChatListBoxStyle}"
                 Margin="10"
                 VirtualizingStackPanel.IsVirtualizing="False">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <!-- 프로필 아이콘 -->
                        <Ellipse Width="35" Height="35" Fill="#ffd1dc" VerticalAlignment="Top" Margin="0,0,8,0"/>

                        <!-- 말풍선 -->
                        <Border Background="White" CornerRadius="0,15,15,15" Padding="12,8" MaxWidth="220">
                            <TextBlock Text="{Binding}" 
                                       TextWrapping="Wrap" 
                                       Foreground="#444444" 
                                       FontSize="12" 
                                       FontFamily="Malgun Gothic"/>
                        </Border>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <!-- 아이템 선택 시 파란 배경 제거 -->
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

        <!-- 하단 컨트롤 영역 -->
        <Border Grid.Row="2" Background="White" Padding="15,10" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <UniformGrid Columns="2" Height="45">
                <Button Content="시작" 
                        Command="{Binding StartCommand}" 
                        IsEnabled="{Binding IsStartEnabled}" 
                        Margin="0,0,5,0"/>

                <Button Content="종료" 
                        Command="{Binding StopCommand}" 
                        Background="#A0A0A0"
                        Margin="5,0,0,0"/>
            </UniformGrid>
        </Border>
    </Grid>
</Window>