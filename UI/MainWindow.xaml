<Window x:Class="UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AutoAffectionSkip" Height="400" Width="320"
        Background="#2D2D2D">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ListBox x:Name="LogListBox"
                 Grid.Row="0"
                 ItemsSource="{Binding Logs}" 
                 VirtualizingStackPanel.IsVirtualizing="False"
                 Background="#1E1E1E" 
                 Foreground="#00FF00" 
                 FontSize="11" 
                 FontFamily="Consolas"
                 Margin="0,0,0,10">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding}" TextWrapping="Wrap"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <UniformGrid Grid.Row="1" Columns="2" Height="50">
            <Button Content="시작" 
                    Command="{Binding StartCommand}" 
                    IsEnabled="{Binding IsStartEnabled}" 
                    Margin="0,0,5,0"
                    Background="#3E3E42" Foreground="White" FontWeight="Bold"/>

            <Button Content="종료" 
                    Command="{Binding StopCommand}" 
                    Margin="5,0,0,0"
                    Background="#3E3E42" Foreground="White" FontWeight="Bold"/>
        </UniformGrid>
    </Grid>
</Window>